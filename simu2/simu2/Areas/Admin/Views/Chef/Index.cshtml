@model IEnumerable<simu2.Models.Chef>
@{
    ViewData["Title"] = "Chefs Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <h1>Chef Table</h1>
    <a asp-area="Admin" asp-controller="Chef" asp-action="Create" class="btn btn-success">
        <i class="icon icon-plus"></i> Add New Chef
    </a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Job</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Job</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Image))
                        {
                            <img src="~/assets/images/@item.Image" alt="@item.Name" width="80" height="80" />
                        }
                        else
                        {
                            <span class="text-muted">No image</span>
                        }
                    </td>
                    <td>
                        <a asp-area="Admin" asp-controller="Chef" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                            <i class="icon icon-eye-open"></i> View
                        </a>
                        <a asp-area="Admin" asp-controller="Chef" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                            <i class="icon icon-pencil"></i> Edit
                        </a>
                        <a asp-area="Admin" asp-controller="Chef" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            <i class="icon icon-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-muted">
                    No chefs found. <a asp-area="Admin" asp-controller="Chef" asp-action="Create">Create one</a>
                </td>
            </tr>
        }
    </tbody>
</table>